{
  "$schema": "./node_modules/oxfmt/configuration_schema.json",
  "useTabs": false,
  "tabWidth": 2,
  "printWidth": 100,
  "singleQuote": false,
  "jsxSingleQuote": false,
  "quoteProps": "as-needed",
  "trailingComma": "all",
  "semi": true,
  "arrowParens": "always",
  "bracketSameLine": false,
  "bracketSpacing": true,
  "ignorePatterns": [
    "*.lock",
    "**/*.gen.ts",
    "**/*.gen.tsx",
    "packages/Auto-claude-code-research-in-sleep/**/*.py",
    "packages/Auto-claude-code-research-in-sleep/**/*.md",
    "packages/Auto-claude-code-research-in-sleep/tools",
    "packages/Auto-claude-code-research-in-sleep/mcp-servers",
    "packages/Auto-claude-code-research-in-sleep/skills",
    "packages/Auto-claude-code-research-in-sleep/templates",
    "packages/Auto-claude-code-research-in-sleep/tests",
    "packages/Auto-claude-code-research-in-sleep/aris-monitor"
  ]
}
